# =============================================================================
# Server-only secrets (Vercel → Project Settings → Environment Variables)
# Never prefix with VITE_ — these must not reach the browser.
# =============================================================================

# Stripe (subscriptions / billing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Supabase (server / SSR / middleware)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Site origin for Stripe redirects and server-side links
SITE_URL=https://www.solverwebsite.com

# Contact form (Telegram lead notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Public client variables (VITE_ prefix — embedded in the browser bundle)
# =============================================================================

# Supabase (browser client; can mirror SUPABASE_URL / anon key)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# SEO / Open Graph canonical origin
VITE_SITE_ORIGIN=https://www.solverwebsite.com
